#!/bin/sh
set -eu

cd "$(dirname "$0")/.."

service="circlemud"
was_running=0

container_id="$(docker compose ps -q "$service" 2>/dev/null || true)"
if [ -n "$container_id" ]; then
  running="$(docker inspect -f '{{.State.Running}}' "$container_id" 2>/dev/null || true)"
  if [ "$running" = "true" ]; then
    was_running=1
  fi
fi

if [ "$was_running" -eq 1 ]; then
  echo "Stopping $service..."
  docker compose stop "$service"
fi

echo "Resetting player data..."

for dir in lib/plrfiles lib/plrobjs lib/plrvars; do
  if [ -d "$dir" ]; then
    find "$dir" -type f -delete
  fi
done

rm -f lib/plrfiles/index lib/etc/plrmail lib/etc/last

for dir in \
  lib/plrfiles/A-E lib/plrfiles/F-J lib/plrfiles/K-O lib/plrfiles/P-T lib/plrfiles/U-Z lib/plrfiles/ZZZ \
  lib/plrobjs/A-E lib/plrobjs/F-J lib/plrobjs/K-O lib/plrobjs/P-T lib/plrobjs/U-Z lib/plrobjs/ZZZ \
  lib/plrvars/A-E lib/plrvars/F-J lib/plrvars/K-O lib/plrvars/P-T lib/plrvars/U-Z lib/plrvars/ZZZ
do
  mkdir -p "$dir"
  touch "$dir/00"
done

if [ "$was_running" -eq 1 ]; then
  echo "Starting $service..."
  docker compose start "$service"
fi

echo "Player data reset complete."
